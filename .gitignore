###############################################################################
# LoLMatchAnalyzer
#
# Git Ignore Rules
#
# このファイルでは、Git管理対象外とするファイル・ディレクトリを定義する。
###############################################################################


###############################################################################
# Python
###############################################################################

__pycache__/
*.py[cod]
*$py.class


###############################################################################
# Virtual Environment
###############################################################################

.venv/
venv/
env/


###############################################################################
# Environment Variables
#
# APIキーや個人情報を含むため、Git管理しない。
###############################################################################

.env


###############################################################################
# Logs
###############################################################################

logs/
*.log


###############################################################################
# Database
#
# SQLiteデータベースは実行時に生成される。
###############################################################################

data/*.db
data/*.sqlite
data/*.sqlite3


###############################################################################
# VS Code
###############################################################################

.vscode/


###############################################################################
# JetBrains IDE
###############################################################################

.idea/


###############################################################################
# OS Files
###############################################################################

.DS_Store
Thumbs.db


###############################################################################
# Python Build
###############################################################################

build/
dist/
*.egg-info/


###############################################################################
# Python Test / Cache
###############################################################################

.pytest_cache/
.mypy_cache/
.coverage
htmlcov/


###############################################################################
# Temporary Files
###############################################################################

*.tmp
*.temp